{
  "_doc": "ES-090 CRIT-2 — XSS payloads for sanitize-html unit + integration tests. Each entry has 'in' (raw payload) and 'expectStripped' (substrings that MUST NOT appear after sanitizeMarkdown()). Sources: OWASP XSS cheat sheet, HackerOne disclosed reports, DOMPurify regression suite.",
  "payloads": [
    {
      "id": "P1",
      "name": "script tag",
      "in": "<script>alert(1)</script>hi",
      "expectStripped": ["<script", "alert(1)"],
      "expectContains": ["hi"]
    },
    {
      "id": "P2",
      "name": "img onerror",
      "in": "<img src=x onerror=\"alert(1)\">",
      "expectStripped": ["onerror", "alert(1)"]
    },
    {
      "id": "P3",
      "name": "javascript: URL",
      "in": "<a href=\"javascript:alert(1)\">click</a>",
      "expectStripped": ["javascript:", "alert(1)"],
      "expectContains": ["click"]
    },
    {
      "id": "P4",
      "name": "iframe",
      "in": "<iframe src=\"https://evil.com\"></iframe>",
      "expectStripped": ["<iframe", "evil.com"]
    },
    {
      "id": "P5",
      "name": "style tag with expression",
      "in": "<style>body{background:url('javascript:alert(1)')}</style>",
      "expectStripped": ["<style", "javascript:"]
    },
    {
      "id": "P6",
      "name": "svg onload",
      "in": "<svg onload=\"alert(1)\"></svg>",
      "expectStripped": ["onload", "alert(1)"]
    },
    {
      "id": "P7",
      "name": "data: URI in img",
      "in": "<img src=\"data:text/html,<script>alert(1)</script>\">",
      "expectStripped": ["<script", "alert(1)"]
    },
    {
      "id": "P8",
      "name": "object embed",
      "in": "<object data=\"evil.swf\"></object><embed src=\"evil.swf\">",
      "expectStripped": ["<object", "<embed", "evil.swf"]
    },
    {
      "id": "P9",
      "name": "meta http-equiv refresh",
      "in": "<meta http-equiv=\"refresh\" content=\"0;url=https://evil.com\">",
      "expectStripped": ["<meta", "evil.com"]
    },
    {
      "id": "P10",
      "name": "link stylesheet exfil",
      "in": "<link rel=\"stylesheet\" href=\"https://evil.com/x.css\">",
      "expectStripped": ["<link", "evil.com"]
    },
    {
      "id": "P11",
      "name": "event handler onmouseover",
      "in": "<p onmouseover=\"alert(1)\">hover</p>",
      "expectStripped": ["onmouseover", "alert(1)"],
      "expectContains": ["hover"]
    },
    {
      "id": "P12",
      "name": "safe bold/italic preserved",
      "in": "<strong>bold</strong> and <em>italic</em>",
      "expectStripped": [],
      "expectContains": ["<strong>", "<em>", "bold", "italic"]
    },
    {
      "id": "P13",
      "name": "safe https link preserved",
      "in": "<a href=\"https://flowblinq.com\" rel=\"noopener\">flow</a>",
      "expectStripped": [],
      "expectContains": ["href=\"https://flowblinq.com\"", "flow"]
    },
    {
      "id": "P14",
      "name": "encoded script tag",
      "in": "&lt;script&gt;alert(1)&lt;/script&gt;",
      "expectStripped": [],
      "expectContains": ["script"]
    },
    {
      "id": "P15",
      "name": "nested malicious tags",
      "in": "<div><script>alert(1)</script><img src=x onerror=alert(2)></div>",
      "expectStripped": ["<script", "onerror", "alert(1)", "alert(2)"]
    }
  ]
}
