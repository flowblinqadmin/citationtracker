# ── bulk-csv-qa integration test environment ──────────────────────────────────
# Copy this file to .env.test in the geo/ root and fill in values.
# NEVER commit .env.test — it contains service-role keys.

# Base URL of the running server (Docker staging or Vercel preview)
TEST_BASE_URL=http://localhost:3030

# Supabase — use your project's URL and service-role key
TEST_SUPABASE_URL=https://your-project.supabase.co
TEST_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SERVICE_ROLE_PLACEHOLDER

# Test account — must have an existing team in Supabase
# Use qa-bulk@flowblinq.com or your designated QA account
TEST_USER_EMAIL=qa-bulk@flowblinq.com
TEST_USER_PASSWORD=your-test-account-password

# Firecrawl — staging key (may have lower rate limits than prod)
TEST_FIRECRAWL_API_KEY=fc-your-staging-key

# Credits to seed before each test tier
# 500 for smoke, bumped to 1000 for load tier in load.test.ts
CREDITS_SEED_AMOUNT=500
