# API Client Integration Tests — Environment Variables
# Copy to geo/.env.test and fill in real values.
# These variables are loaded by vitest.api-client.config.ts automatically.
#
# See tests/integration/api-client/README.md for full documentation.

# ─── Required ─────────────────────────────────────────────────────────────────

# Vercel deployment URL (no trailing slash)
TEST_BASE_URL=https://geo.flowblinq.com

# Supabase service role credentials (same project as the app)
TEST_SUPABASE_URL=https://your-project.supabase.co
TEST_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Test team ID — must exist in Supabase, must have free tier available
TEST_TEAM_ID=your-team-id-here

# ─── Audit domains ────────────────────────────────────────────────────────────

# Primary domain for audit-flow.test.ts (F-1 through F-7).
# Must be a real, publicly accessible https:// URL that Firecrawl can scrape.
# Example: https://example.com
TEST_AUDIT_DOMAIN=https://example.com

# Separate domain for free-tier.test.ts (T-2 through T-4).
# Use a different domain from TEST_AUDIT_DOMAIN to avoid 409 collisions
# (audit-flow.test.ts runs first and exhausts run1 on TEST_AUDIT_DOMAIN).
# Must also be a real, scrapeable domain.
# Falls back to TEST_AUDIT_DOMAIN if not set (risk of collision).
TEST_FREE_TIER_DOMAIN=https://another-test-domain.com

# Optional fallback for F-3 retry if the primary pipeline run fails
# TEST_AUDIT_DOMAIN_FALLBACK=https://fallback-domain.com

# ─── Optional: manual credential override ─────────────────────────────────────

# If set, setup.ts skips DB provisioning and uses these credentials directly.
# Useful for re-running tests without creating new api_client rows each time.
# Credentials must already exist in the Supabase api_clients table.
# TEST_CLIENT_ID=test_your_client_id
# TEST_CLIENT_SECRET=your_client_secret_here
