# Shared Supabase Postgres (pooler, port 6543) — same database as geo
DATABASE_URL=

# Same Supabase project as geo (session cookies must validate here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# MUST equal geo's CRON_SECRET (authorizes geo's tracker worker + our cron).
# Rotating it = update BOTH Vercel projects.
CRON_SECRET=

# Same QStash account as geo — the run route publishes worker jobs through it.
# When unset (local dev), the worker is called directly, fire-and-forget.
# QSTASH_URL must be the account's REGIONAL endpoint (geo: qstash-us-east-1).
QSTASH_TOKEN=
QSTASH_URL=

# Deployed geo origin (login, buy-credits, tracker worker). Defaults to
# https://geo.flowblinq.com when unset.
GEO_ORIGIN=
