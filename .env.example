# Shared Supabase Postgres (pooler, port 6543) — same database as geo
DATABASE_URL=

# Same Supabase project as geo (session cookies must validate here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Worker + cron auth. Must equal geo's CRON_SECRET until geo's tracker is
# deleted (its :30 cron/worker still run during the transition window).
CRON_SECRET=

# QStash — the run route and the worker's self-resume publish through it.
# When unset (local dev), the worker is called directly, fire-and-forget.
# QSTASH_URL must be the account's REGIONAL endpoint (qstash-us-east-1) or
# publishes 404. Signing keys verify inbound worker deliveries.
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Provider keys for the in-repo engine (lib/engine/providers.ts).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Public base URL of THIS service — the DIRECT vercel.app URL including the
# /citations basePath, never the geo rewrite (QStash signatures are exact-URL).
# Defaults to https://citationtracker.vercel.app/citations.
CITATIONS_WORKER_BASE=

# Citation verification + AI Search scrapes.
FIRECRAWL_API_KEY=

# Deployed geo origin (login, buy-credits). Defaults to
# https://geo.flowblinq.com when unset.
GEO_ORIGIN=

# Transition switch. While geo's own tracker cron is still deployed, leave this
# UNSET — our scheduler cron then does only the retention purge and lets geo own
# scheduling + stale recovery (running both double-spends provider budget).
# Phase C sets this to "false" (we take over) in the same change that deletes
# geo's cron.
GEO_TRACKER_LIVE=
